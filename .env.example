# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wassce:wassce@db:5432/wassce_analytics
DIRECT_URL=postgresql://wassce:wassce@db:5432/wassce_analytics

# ─── Auth (Auth.js v5 — note: AUTH_SECRET not NEXTAUTH_SECRET) ────────────────
AUTH_SECRET=replace-with-32-char-random-secret
AUTH_URL=http://localhost:3000

# ─── Services ─────────────────────────────────────────────────────────────────
PARSER_SERVICE_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379/0

# ─── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wassce-uploads
MINIO_USE_SSL=false

# ─── App ──────────────────────────────────────────────────────────────────────
BASE_DOMAIN=wassce-analytics.com
NEXT_PUBLIC_BASE_DOMAIN=wassce-analytics.com
NODE_ENV=development
